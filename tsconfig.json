{
  "compilerOptions": {
    "module": "commonjs",
    "esModuleInterop": true,
    "target": "ES2022",
    "noImplicitAny": true,
    "moduleResolution": "Node",
    "sourceMap": true,
    "types": [
      "vitest/globals"
    ],
    "skipLibCheck": true,
    "rootDir": ".",
    "strict": true,
    "noEmit": false,
    "resolveJsonModule": true,
    "noUnusedLocals": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "src/*": [
        "src/*"
      ],
      "@Shared/*": [
        "src/Contexts/Shared/*"
      ],
      "@Apps/*": [
        "src/apps/*"
      ],
      "@Tests/*": [
        "tests/*"
      ],
      "@Core/*": [
        "src/Contexts/Core/*"
      ]
    }
  },
  "include": [
    "src/**/**.ts",
    "tests/**/**.ts"
, "src/apps/Core/routes/http/BankOperation"  ],
  "exclude": [
    "node_modules"
  ]
}