{
  "name": "pantaleon",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "prepare": "ts-patch install",
    "lint": "eslint src/* tests/* --ext .ts,.tsx",
    "lint:fix": "npm run lint -- --fix --no-error-on-unmatched-pattern",
    "start:core:server": "npm run migrations:core:run && node dist/src/apps/Core/index",
    "start:core:server:dev": "cross-env NODE_ENV=development nodemon --config nodemon.config.json -r tsconfig-paths/register src/apps/Core/index.ts",
    "build": "node ./etc/build/build.js",
    "migrations:core:generate": "ts-node -r tsconfig-paths/register node_modules/typeorm/cli.js migration:generate persistence/migrations/core/core -d src/apps/Core/dataSource -o",
    "migrations:core:run": "ts-node -r tsconfig-paths/register node_modules/typeorm/cli.js migration:run -d src/apps/Core/dataSource",
    "migrations:core:revert": "ts-node -r tsconfig-paths/register node_modules/typeorm/cli.js migration:revert -d src/apps/Core/dataSource"
  },
  "author": "Eloi",
  "license": "ISC",
  "dependencies": {
    "@types/bcrypt": "^6.0.0",
    "bcrypt": "^5.1.1",
    "body-parser": "^1.20.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "currency.js": "^2.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.0",
    "firebase-admin": "^13.0.1",
    "glob": "^11.0.0",
    "helmet": "^7.1.0",
    "http": "^0.0.1-security",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "node-dependency-injection": "^3.2.0",
    "path": "^0.12.7",
    "pg": "^8.13.1",
    "socket.io": "^4.8.3",
    "typeorm": "^0.3.20",
    "uuid": "^11.0.3",
    "uuid-validate": "^0.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@faker-js/faker": "^9.2.0",
    "@types/body-parser": "^1.19.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/glob": "^8.1.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.13",
    "@types/node": "^22.9.0",
    "@types/socket.io": "^3.0.2",
    "@types/uuid-validate": "^0.0.3",
    "@typescript-eslint/eslint-plugin": "^8.7.0",
    "@typescript-eslint/parser": "^8.7.0",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.1",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.6.0",
    "globals": "^15.12.0",
    "husky": "^9.1.6",
    "nodemon": "^3.1.7",
    "prettier": "^3.3.3",
    "resolve-tspaths": "^0.8.23",
    "ts-node": "^10.9.2",
    "ts-patch": "^3.2.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.14.0",
    "typescript-transform-paths": "^3.5.3",
    "vitest": "^2.1.4",
    "vitest-mock-extended": "^2.0.2"
  }
}
